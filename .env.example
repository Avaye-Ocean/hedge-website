# ============================================================
# Hedge Website — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Server
PORT=6300
NODE_ENV=development

# App version — leave blank to auto-detect from git commit hash
APP_VERSION=

# --- Vendorstack Backend API ---
# Base URL for the backend (must end with trailing slash)
BACKEND_API_URL=https://dev-vendorstack-backend.herokuapp.com/api/v1/
# Static API key sent with every request
BACKEND_API_KEY=your-api-key-here
# Source/tenant identifier for this storefront
BACKEND_SOURCE_ID=HEDGE_WEARSLY_LTD
# MongoDB ObjectId of the Hedge Wears business
BACKEND_BUSINESS_ID=your-business-id-here

# --- App URLs ---
# Web shop (Next.js app)
WEB_SHOP_APP_URL=https://dev-hedge-web-app-82768f1c25de.herokuapp.com
# Mobile apps (deep links / app store pages)
IOS_SHOP_APP_URL=https://apps.apple.com/app/hedge-wears
ANDROID_SHOP_APP_URL=https://play.google.com/store/apps/details?id=com.hedgewears
