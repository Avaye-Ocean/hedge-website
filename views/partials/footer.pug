footer.footer
  .footer-inner.container
    .footer-top
      .footer-brand
        a.footer-logo(href='/')
          svg.footer-logo-icon(width='36' height='19' viewBox='0 0 76 40' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
            path(d='M67.83 0V3.18928C67.83 6.64845 65.895 9.83773 62.8312 11.4058L42.0844 22.0007V0H33.9144V3.18928C33.9144 6.64845 31.9794 9.83773 28.9156 11.4058L8.16881 22.0007V0H0V40H8.17V36.8107C8.17 33.3515 10.105 30.1623 13.1688 28.5942L33.9156 17.9993V39.9994H42.0856V36.8101C42.0856 33.351 44.0206 30.1617 47.0844 28.5936L67.8312 17.9987V39.9988H76.0012V0H67.8312H67.83Z' fill='currentColor')
          span.footer-logo-text HEDGE WEARS
        p.footer-tagline Style Beyond Seasons.
        .footer-social
          a.footer-social-link(href='https://instagram.com/hedgewears' target='_blank' rel='noopener' aria-label='Hedge Wears on Instagram')
            span(aria-hidden='true') IG
          a.footer-social-link(href='https://twitter.com/hedgewears' target='_blank' rel='noopener' aria-label='Hedge Wears on X (Twitter)')
            span(aria-hidden='true') X
          a.footer-social-link(href='https://facebook.com/hedgewears' target='_blank' rel='noopener' aria-label='Hedge Wears on Facebook')
            span(aria-hidden='true') FB

      .footer-links
        .footer-links-col
          p.footer-links-heading Shop
          ul.footer-links-list
            li: a.footer-link(href='/collections') Collections
            li: a.footer-link(href='/products') Products
            li: a.footer-link(href='/categories') Categories
            li: a.footer-link(href=webShopUrl target='_blank' rel='noopener') Web Store

        .footer-links-col
          p.footer-links-heading Company
          ul.footer-links-list
            li: a.footer-link(href='/about') About
            li: a.footer-link(href='/features') Features
            li: a.footer-link(href='/pricing') Pricing
            li: a.footer-link(href='/contact') Contact

        .footer-links-col
          p.footer-links-heading Support
          ul.footer-links-list
            li: a.footer-link(href='/download') Download App
            li: a.footer-link(href='/help') Help Center
            li: a.footer-link(href='/privacy') Privacy Policy
            li: a.footer-link(href='/terms') Terms of Service

      .footer-apps
        p.footer-links-heading Get the App
        a.app-badge(href=iosUrl target='_blank' rel='noopener' aria-label='Download on App Store')
          span.app-badge-sub Download on
          span.app-badge-main App Store
        a.app-badge(href=androidUrl target='_blank' rel='noopener' aria-label='Get it on Google Play')
          span.app-badge-sub Get it on
          span.app-badge-main Google Play

    .footer-bottom
      p.footer-copyright &copy; #{year} Hedge Wears. All rights reserved.
      .footer-bottom-links
        a.footer-link-sm(href='/privacy') Privacy Policy
        a.footer-link-sm(href='/terms') Terms
        a.footer-link-sm(href='/cookies') Cookies
