mixin icon-bag(size, color)
  - var s = size || 24
  - var c = color || 'currentColor'
  svg(width=s height=s viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true")
    path(d="M6.5 8V7a5.5 5.5 0 0 1 11 0v1" stroke=c stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round")
    rect(x="3.5" y="8" width="17" height="13" rx="2" stroke=c stroke-width="1.8" stroke-linejoin="round")
    circle(cx="9" cy="13.5" r="0.9" fill=c)
    circle(cx="15" cy="13.5" r="0.9" fill=c)

