extends layout

block pageTitle
  title Style Beyond Seasons — Hedge Wears

block metaDesc
  meta(name='description' content='Hedge Wears — African creativity on the global stage. Discover fashion from local designers. Earn HedgeCoin on every order.')

block content

  //- ─── HERO ──────────────────────────────────────────────────────────────────
  section.hero.hero--image.section(style='background-image: url("https://hedgewears.com/wp-content/uploads/2025/10/ctaimage.webp")')
    .hero-overlay
    .container
      .hero-inner
        .hero-content
          h1.hero-title Style Beyond Seasons
          p.hero-subtitle African creativity on the global stage. Refined classics with cultural weight and contemporary relevance.
          .hero-cta-group
            a.btn.btn-primary.btn-lg(href=webShopUrl target='_blank' rel='noopener') Shop the Collection
            a.btn.btn-outline-white.btn-lg(href='/download') Download App

  //- ─── CATEGORY STRIP ────────────────────────────────────────────────────────
  section.categories-strip.section
    .container
      .section-header
        h2.section-title Explore By Category
      .category-strip-scroll
        if categories && categories.length > 0
          each category in categories
            - const catImg = category.photo || 'https://hedgewears.com/wp-content/uploads/2025/10/ctaimage.webp'
            a.category-card(href=webShopUrl + '/?categories=' + category._id target='_blank' rel='noopener')
              .category-card-img-wrap
                img.category-card-img(src=catImg alt=category.name + ' category' loading='lazy')
              .category-card-info
                span.category-card-name= category.name
                span.category-card-cta Shop →
        else
          a.category-card(href=webShopUrl + '/?productGender=FEMALE' target='_blank' rel='noopener')
            .category-card-img-wrap
              img.category-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/card1.jpeg' alt="Women's Bags" loading='lazy')
            .category-card-info
              span.category-card-name Women's Bags
              span.category-card-cta Shop →
          a.category-card(href=webShopUrl + '/?productGender=FEMALE' target='_blank' rel='noopener')
            .category-card-img-wrap
              img.category-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/Card2.webp' alt="Women's Shoes" loading='lazy')
            .category-card-info
              span.category-card-name Women's Shoes
              span.category-card-cta Shop →
          a.category-card(href=webShopUrl + '/?productGender=MALE' target='_blank' rel='noopener')
            .category-card-img-wrap
              img.category-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/Card3.jpeg' alt="Men's Bags" loading='lazy')
            .category-card-info
              span.category-card-name Men's Bags
              span.category-card-cta Shop →
          a.category-card(href=webShopUrl + '/?productGender=MALE' target='_blank' rel='noopener')
            .category-card-img-wrap
              img.category-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/card4.webp' alt="Men's Shoes" loading='lazy')
            .category-card-info
              span.category-card-name Men's Shoes
              span.category-card-cta Shop →
      .section-footer-link
        a.link(href='/categories') View all categories →

  //- ─── FEATURED PRODUCTS ─────────────────────────────────────────────────────
  section.featured-products.section
    .container
      .section-header
        span.section-eyebrow New Arrivals
        h2.section-title The Meridian Collection
      .products-grid
        if featuredProducts && featuredProducts.length > 0
          each product, i in featuredProducts.slice(0, 8)
            - const imgUrl = (product.thumbnailPhotos && product.thumbnailPhotos[0]) || (product.photos && product.photos[0]) || 'https://hedgewears.com/wp-content/uploads/2025/10/trending-big.webp'
            a.product-card(href=webShopUrl + '/product/' + product._id target='_blank' rel='noopener')
              .product-card-img-wrap
                img.product-card-img(src=imgUrl alt=product.name loading='lazy')
              .product-card-info
                span.product-card-name= product.name
                span.product-price
                  img.hgc-icon-inline(src='/img/hgc-icon.svg' alt='HGC')
                  = product.sellingPriceCoin
              span.product-card-link View →
        else
          a.product-card(href=webShopUrl target='_blank' rel='noopener')
            .product-card-img-wrap
              img.product-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/trendy-dress-1.webp' alt='Dress from the Meridian Collection' loading='lazy')
            .product-card-info
              span.product-card-name Meridian Dress
              span.product-price
                img.hgc-icon-inline(src='/img/hgc-icon.svg' alt='HGC')
                | 280
            span.product-card-link View →
          a.product-card(href=webShopUrl target='_blank' rel='noopener')
            .product-card-img-wrap
              img.product-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/trendy-shoe.webp' alt='Shoes from the Meridian Collection' loading='lazy')
            .product-card-info
              span.product-card-name Meridian Sneakers
              span.product-price
                img.hgc-icon-inline(src='/img/hgc-icon.svg' alt='HGC')
                | 320
            span.product-card-link View →
          a.product-card(href=webShopUrl target='_blank' rel='noopener')
            .product-card-img-wrap
              img.product-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/trendy-jewelry.webp' alt='Jewelry from the Meridian Collection' loading='lazy')
            .product-card-info
              span.product-card-name Gold Layer Set
              span.product-price
                img.hgc-icon-inline(src='/img/hgc-icon.svg' alt='HGC')
                | 150
            span.product-card-link View →
          a.product-card(href=webShopUrl target='_blank' rel='noopener')
            .product-card-img-wrap
              img.product-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/trending-big.webp' alt='Handbag from the Meridian Collection' loading='lazy')
            .product-card-info
              span.product-card-name Structured Tote
              span.product-price
                img.hgc-icon-inline(src='/img/hgc-icon.svg' alt='HGC')
                | 410
            span.product-card-link View →
      .section-footer-cta
        a.btn.btn-primary(href=webShopUrl target='_blank' rel='noopener') View all products →

  //- ─── EDITORIAL / CTA BAND ──────────────────────────────────────────────────
  section.editorial-band.section.section--dark(style='background-image: url("https://hedgewears.com/wp-content/uploads/2025/10/trending-big.webp")')
    .editorial-band-overlay
    .container
      .editorial-band-inner
        h2.editorial-band-title The Collective
        p.editorial-band-sub Crafted with intention, worn with purpose.
        a.btn.btn-white.btn-lg(href=webShopUrl target='_blank' rel='noopener') Discover the Collection

  //- ─── TRENDING CATEGORIES ───────────────────────────────────────────────────
  section.trending-tags.section
    .container
      .section-header
        h2.section-title Trending Now
      .tags-row
        if categories && categories.length > 0
          each category in categories
            a.tag-pill(href=webShopUrl + '/?categories=' + category._id target='_blank' rel='noopener')= category.name
        else
          a.tag-pill(href=webShopUrl target='_blank' rel='noopener') Bags
          a.tag-pill(href=webShopUrl target='_blank' rel='noopener') Shoes
          a.tag-pill(href=webShopUrl target='_blank' rel='noopener') Dresses
          a.tag-pill(href=webShopUrl target='_blank' rel='noopener') Jewelry
          a.tag-pill(href=webShopUrl target='_blank' rel='noopener') Blazers
          a.tag-pill(href=webShopUrl target='_blank' rel='noopener') Accessories

  //- ─── HEDGECOIN FEATURE ─────────────────────────────────────────────────────
  section.hedgecoin-feature.section.section--muted
    .container
      .hedgecoin-feature-inner
        .hedgecoin-feature-content
          span.section-eyebrow HedgeCoin Rewards
          h2.section-title Earn HedgeCoin on every order
          p.hedgecoin-feature-desc Every purchase earns HGC — redeem for discounts on your next order. The more you shop, the more you save. Your balance never expires while your account is active.
          a.btn.btn-primary(href=webShopUrl target='_blank' rel='noopener') Start Earning

        .hedgecoin-feature-visual
          .coin-card
            .coin-card-header
              span.coin-card-label HGC Balance
              img.hgc-icon-card-header(src='/img/hgc-icon.svg' alt='HGC')
            .coin-card-amount
              img.hgc-icon-coin-card(src='/img/hgc-icon.svg' alt='HGC')
              span.coin-card-amount-sub Your loyalty, rewarded.
            .coin-card-tx
              .coin-tx-item
                span.coin-tx-label Order completed
                span.coin-tx-amount +45
                  img.hgc-icon-inline(src='/img/hgc-icon.svg' alt='HGC')
              .coin-tx-item
                span.coin-tx-label Order completed
                span.coin-tx-amount +30
                  img.hgc-icon-inline(src='/img/hgc-icon.svg' alt='HGC')

  //- ─── APP DOWNLOAD STRIP ────────────────────────────────────────────────────
  section.app-strip.section.section--accent
    .container
      .app-strip-inner
        h2.app-strip-title Shop anywhere. Download the app.
        .app-strip-buttons
          a.app-badge.app-badge--large(href=iosUrl target='_blank' rel='noopener' aria-label='Download on App Store')
            .app-badge-icon
              svg(width='22' height='22' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
                path(d='M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z' fill='currentColor')
            .app-badge-text
              span.app-badge-sub Download on
              span.app-badge-main App Store
          a.app-badge.app-badge--large(href=androidUrl target='_blank' rel='noopener' aria-label='Get it on Google Play')
            .app-badge-icon
              svg(width='22' height='22' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
                path(d='M3.18 23.76c.3.17.63.24.97.2L15.72 12 12 8.28 3.18 23.76zM20.48 10.26l-3.04-1.75-4.02 3.49 4.02 3.49 3.07-1.77c.87-.5.87-1.96-.03-2.46zM2.01 1.23C1.64 1.56 1.4 2.08 1.4 2.76V21.2c0 .68.24 1.2.62 1.53L3.18.24 2.01 1.23zM15.72 12L3.18.24l9.84 11.76L15.72 12z' fill='currentColor')
            .app-badge-text
              span.app-badge-sub Get it on
              span.app-badge-main Google Play
