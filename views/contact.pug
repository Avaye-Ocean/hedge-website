extends layout

block pageTitle
  title Contact — Hedge Wears

block metaDesc
  meta(name='description' content='Get in touch with Hedge Wears — for business inquiries, support, or just to say hello.')

block content

  //- ─── PAGE HERO ─────────────────────────────────────────────────────────────
  section.page-hero.section
    .container
      .page-hero-inner.page-hero-inner--centered
        span.section-eyebrow We're here
        h1.page-hero-title Get in touch
        p.page-hero-subtitle For business inquiries, support, or partnerships — reach us any time.

  //- ─── CONTACT OPTIONS ───────────────────────────────────────────────────────
  section.contact-options.section
    .container
      .contact-options-grid
        .contact-option-card
          .contact-option-icon
            svg(width='28' height='28' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
              path(d='M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round')
              path(d='M22 6l-10 7L2 6' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round')
          h3.contact-option-title Email
          p.contact-option-desc For general enquiries and business partnerships.
          a.contact-option-link(href='mailto:hello@hedgewears.com') hello@hedgewears.com

        .contact-option-card
          .contact-option-icon
            svg(width='28' height='28' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
              rect(x='2' y='2' width='20' height='20' rx='5' stroke='currentColor' stroke-width='1.8')
              circle(cx='12' cy='12' r='4' stroke='currentColor' stroke-width='1.8')
              circle(cx='17.5' cy='6.5' r='1' fill='currentColor')
          h3.contact-option-title Instagram
          p.contact-option-desc See new arrivals, behind-the-scenes, and brand stories.
          a.contact-option-link(href='https://instagram.com/hedgewears' target='_blank' rel='noopener') @hedgewears

        .contact-option-card
          .contact-option-icon
            svg(width='28' height='28' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
              path(d='M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round')
          h3.contact-option-title Twitter / X
          p.contact-option-desc Updates, announcements, and community conversations.
          a.contact-option-link(href='https://twitter.com/hedgewears' target='_blank' rel='noopener') @hedgewears

  //- ─── CONTACT FORM ──────────────────────────────────────────────────────────
  section.contact-form-section.section.section--muted
    .container
      .contact-form-wrap
        .contact-form-header
          span.section-eyebrow Send a message
          h2.contact-form-title We'd love to hear from you
          p.contact-form-sub For business inquiries:
            a.link(href='mailto:hello@hedgewears.com') hello@hedgewears.com
        form.contact-form(action='#' method='post' novalidate)
          .form-row
            .form-group
              label.form-label(for='contact-name') Name
              input.form-input(type='text' id='contact-name' name='name' placeholder='Your name' autocomplete='name')
            .form-group
              label.form-label(for='contact-email') Email
              input.form-input(type='email' id='contact-email' name='email' placeholder='your@email.com' autocomplete='email')
          .form-group
            label.form-label(for='contact-subject') Subject
            input.form-input(type='text' id='contact-subject' name='subject' placeholder='What is this about?')
          .form-group
            label.form-label(for='contact-message') Message
            textarea.form-textarea(id='contact-message' name='message' rows='6' placeholder='Tell us how we can help…')
          button.btn.btn-primary.btn-lg(type='submit') Send Message
