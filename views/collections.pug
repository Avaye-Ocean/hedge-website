extends layout

block pageTitle
  title Collections — Hedge Wears

block metaDesc
  meta(name='description' content='Explore curated collections from Hedge Wears — The Meridian Collection, Street & Sport, and more from African designers.')

block content

  //- ─── HERO ──────────────────────────────────────────────────────────────────
  section.collections-hero.hero--image.section(style='background-image: url("https://hedgewears.com/wp-content/uploads/2025/10/ctaimage.webp")')
    .hero-overlay
    .container
      .collections-hero-inner
        span.section-eyebrow Curated for you
        h1.collections-hero-title The Collections
        p.collections-hero-sub Refined classics with cultural weight and contemporary relevance.

  //- ─── MERIDIAN COLLECTION ───────────────────────────────────────────────────
  section.collection-editorial.section
    .container
      .collection-editorial-inner
        .collection-editorial-img-wrap
          img.collection-editorial-img(src='https://hedgewears.com/wp-content/uploads/2025/10/trendy-dress-1.webp' alt='Model wearing a dress from the Meridian Collection' loading='lazy')
        .collection-editorial-content
          span.section-eyebrow Collection 01
          h2.collection-editorial-title The Meridian Collection
          p.collection-editorial-desc Flowing silhouettes, deliberate cuts, and a palette drawn from natural textures. The Meridian Collection is for those who move with intention. Each piece is designed to carry you from morning markets to evening gatherings without compromise.
          a.btn.btn-primary(href=webShopUrl + '/explore' target='_blank' rel='noopener') Shop Meridian

  //- ─── STREET & SPORT ────────────────────────────────────────────────────────
  section.collection-editorial.section.section--muted
    .container
      .collection-editorial-inner.collection-editorial-inner--reverse
        .collection-editorial-content
          span.section-eyebrow Collection 02
          h2.collection-editorial-title Street &amp; Sport
          p.collection-editorial-desc Bold colourways and relaxed fits built for the city. Street &amp; Sport blends performance silhouettes with fashion-forward details — sneakers, crossbodies, and layered separates that hold up wherever the day takes you.
          a.btn.btn-primary(href=webShopUrl + '/explore' target='_blank' rel='noopener') Shop Street &amp; Sport
        .collection-editorial-img-pair
          img.collection-editorial-img.collection-editorial-img--half(src='https://hedgewears.com/wp-content/uploads/2025/10/Card2.webp' alt="Women's shoes from the Street and Sport collection" loading='lazy')
          img.collection-editorial-img.collection-editorial-img--half(src='https://hedgewears.com/wp-content/uploads/2025/10/card4.webp' alt="Men's shoes from the Street and Sport collection" loading='lazy')

  //- ─── COLLECTION PICKS ──────────────────────────────────────────────────────
  section.collection-picks.section
    .container
      .section-header
        span.section-eyebrow From the collections
        h2.section-title Standout Pieces
      .products-grid
        if featuredProducts && featuredProducts.length > 0
          each product, i in featuredProducts.slice(0, 4)
            - const imgUrl = (product.thumbnailPhotos && product.thumbnailPhotos[0]) || (product.photos && product.photos[0]) || 'https://hedgewears.com/wp-content/uploads/2025/10/trending-big.webp'
            a.product-card(href=webShopUrl + '/product/' + product._id target='_blank' rel='noopener')
              .product-card-img-wrap
                img.product-card-img(src=imgUrl alt=product.name loading='lazy')
              .product-card-info
                span.product-card-name= product.name
                span.product-price= product.sellingPriceCoin + ' HGC'
              span.product-card-link View →
        else
          a.product-card(href=webShopUrl + '/explore' target='_blank' rel='noopener')
            .product-card-img-wrap
              img.product-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/trendy-dress-1.webp' alt='Meridian Dress' loading='lazy')
            .product-card-info
              span.product-card-name Meridian Dress
              span.product-price 280 HGC
            span.product-card-link View →
          a.product-card(href=webShopUrl + '/explore' target='_blank' rel='noopener')
            .product-card-img-wrap
              img.product-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/trendy-shoe.webp' alt='Street Sneakers' loading='lazy')
            .product-card-info
              span.product-card-name Street Sneakers
              span.product-price 320 HGC
            span.product-card-link View →
          a.product-card(href=webShopUrl + '/explore' target='_blank' rel='noopener')
            .product-card-img-wrap
              img.product-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/trending-big.webp' alt='Structured Tote' loading='lazy')
            .product-card-info
              span.product-card-name Structured Tote
              span.product-price 410 HGC
            span.product-card-link View →
          a.product-card(href=webShopUrl + '/explore' target='_blank' rel='noopener')
            .product-card-img-wrap
              img.product-card-img(src='https://hedgewears.com/wp-content/uploads/2025/10/trendy-dress.jpeg' alt='Tailored Blazer' loading='lazy')
            .product-card-info
              span.product-card-name Tailored Blazer
              span.product-price 360 HGC
            span.product-card-link View →
      .section-footer-cta
        a.btn.btn-primary(href=webShopUrl + '/explore' target='_blank' rel='noopener') View all collections →
