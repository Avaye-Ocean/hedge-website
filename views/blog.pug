extends layout

block pageTitle
  title Stories &amp; Updates — Hedge Wears

block metaDesc
  meta(name='description' content='Stories, updates, and style guides from the Hedge Wears team. Fashion, culture, and business from Africa and beyond.')

block content

  //- ─── PAGE HERO ─────────────────────────────────────────────────────────────
  section.page-hero.section
    .container
      .page-hero-inner.page-hero-inner--centered
        span.section-eyebrow Our journal
        h1.page-hero-title Stories &amp; Updates
        p.page-hero-subtitle Fashion, culture, and business from the Hedge Wears community.

  //- ─── BLOG POSTS ─────────────────────────────────────────────────────────────
  section.section
    .container
      .blog-grid
        a.blog-card(href='#')
          .blog-card-img-wrap
            img.blog-card-img(
              src='https://hedgewears.com/wp-content/uploads/2025/10/ctaimage.webp'
              alt='Style guide: building a wardrobe with HGC rewards'
              loading='lazy'
            )
          .blog-card-body
            span.blog-card-date May 2025
            h2.blog-card-title How to build a wardrobe that earns rewards
            p.blog-card-excerpt Every purchase on Hedge Wears earns HedgeCoin — but with the right strategy you can stack your balance faster. Here's how our most loyal shoppers are doing it.
            span.blog-card-link Read more →

        a.blog-card(href='#')
          .blog-card-img-wrap
            img.blog-card-img(
              src='https://hedgewears.com/wp-content/uploads/2025/10/trending-big.webp'
              alt='Meet the designers behind the Meridian Collection'
              loading='lazy'
            )
          .blog-card-body
            span.blog-card-date April 2025
            h2.blog-card-title Meet the designers behind the Meridian Collection
            p.blog-card-excerpt The Meridian Collection took eight months to develop — from initial sketches in Lagos to final samples reviewed in London. We sat down with the creative team.
            span.blog-card-link Read more →

        a.blog-card(href='#')
          .blog-card-img-wrap
            img.blog-card-img(
              src='https://hedgewears.com/wp-content/uploads/2025/10/trendy-dress-1.webp'
              alt='Why we built HedgeCoin — a note from our founder'
              loading='lazy'
            )
          .blog-card-body
            span.blog-card-date March 2025
            h2.blog-card-title Why we built HedgeCoin
            p.blog-card-excerpt Most loyalty programmes feel like an afterthought. We wanted ours to feel like a real benefit — one that compounds over time and makes shopping genuinely rewarding.
            span.blog-card-link Read more →

      p.blog-coming-soon More stories coming soon. Follow us on Instagram
        a.link(href='https://instagram.com/hedgewears' target='_blank' rel='noopener')  @hedgewears
        |  for the latest.
