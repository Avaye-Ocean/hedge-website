doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(name='description' content=description || 'Hedge Wears — Discover fashion from local designers. Earn HedgeCoin rewards with every purchase.')
    meta(property='og:title' content=title ? title + ' | Hedge Wears' : 'Hedge Wears')
    meta(property='og:description' content=description || 'Discover fashion from local designers. Earn HedgeCoin rewards with every purchase.')
    meta(property='og:type' content='website')
    meta(property='og:image' content='/assets/og-image.png')
    meta(name='twitter:card' content='summary_large_image')
    meta(name='twitter:title' content=title ? title + ' | Hedge Wears' : 'Hedge Wears')
    meta(name='twitter:description' content=description || 'Discover fashion from local designers. Earn HedgeCoin rewards with every purchase.')
    title= title ? title + ' | Hedge Wears' : 'Hedge Wears — Wear Bold. Shop Smart.'

    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)
    link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Rethink+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap')

    link(rel='stylesheet' href='/css/variables.css?v=' + version)
    link(rel='stylesheet' href='/css/base.css?v=' + version)
    link(rel='stylesheet' href='/css/components.css?v=' + version)
    link(rel='stylesheet' href='/css/layout.css?v=' + version)

    link(rel='icon' type='image/svg+xml' href='/assets/favicon.svg')

  body
    include partials/nav

    main
      block content

    include partials/footer

    if process.env.NODE_ENV === 'production'
      script(src='/js/main.min.js?v=' + version defer)
    else
      script(src='/js/main.js?v=' + version defer)
